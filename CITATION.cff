    given-names: "Nikita"
    alias: "kiskaserver"
type: software
license: MIT
version: "1.0.0"
date-released: "2026-06-24"
url: "https://github.com/kiskaserver/gamepad_airfield"
keywords:
  - acoustics
  - fluid-dynamics
  - synthetic-jet
  - acoustic-streaming
  - infrasound
  - haptics
  - dualsense
  - dualshock
